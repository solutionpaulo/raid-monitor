# ============================================
# RAID Monitor - Configurações
# ============================================
# Copie este arquivo para .env e ajuste os valores

# Servidor Web
PORT=3000
# Use 127.0.0.1 para localhost only (mais seguro)
# Use 0.0.0.0 para permitir acesso da rede local
HOST=127.0.0.1

# Monitoramento
# Intervalo entre verificações em segundos
CHECK_INTERVAL_SECONDS=60

# Modo demo (true = dados simulados, sem executar diskpart)
# Útil para desenvolvimento/testes em máquinas sem RAID
DEMO_MODE=false

# ============================================
# Alertas por Email (opcional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=raid-monitor@seudominio.com
ALERT_EMAIL_TO=admin@seudominio.com

# ============================================
# Webhook (opcional - Teams/Slack/Discord)
# ============================================
WEBHOOK_URL=

# ============================================
# Autenticação (opcional)
# ============================================
# Defina usuário e senha para proteger o dashboard com Basic Auth
# Deixe vazio para acesso sem autenticação
AUTH_USERNAME=
AUTH_PASSWORD=

# ============================================
# Retenção de Dados
# ============================================
# Dias para manter histórico de checks
RETENTION_DAYS=90
